{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/auto-push.js\"",
            "timeout": 30,
            "statusMessage": "Sincronizando con GitHub..."
          }
        ]
      }
    ]
  }
}
