---
/**
 * BaseLayout.astro — Layout base accesible del sitio MBP
 *
 * Características de accesibilidad:
 * - lang="es" en <html> (WCAG + SEO — flag Gemini review)
 * - Skip link "Ir al contenido principal" (visible en :focus-visible)
 * - <main id="main-content"> como destino del skip link
 * - Landmarks ARIA: header / nav / main / footer
 * - prefers-reduced-motion respetado via global.css
 *
 * Header y Footer se importan directamente para garantizar presencia en cada página.
 */

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ClientRouter from 'astro/components/ClientRouter.astro';

export interface Props {
  title: string;
  description?: string;
  robots?: string;
  currentPath?: string;
}

const {
  title,
  description = 'Sitio profesional de medicina pediátrica. Información en proceso de verificación.',
  robots = 'noindex, nofollow',
  currentPath = '/',
} = Astro.props;

const canonicalUrl = Astro.url.href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Colores del tema -->
    <meta name="theme-color" content="#2D320F" />

    <!-- Preconexión a Google Fonts (Josefin Sans) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Favicon temporal — SVG placeholder hasta recibir isotipo definitivo -->
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Ccircle cx='16' cy='16' r='16' fill='%232D320F'/%3E%3Ccircle cx='16' cy='16' r='6' fill='%23DCCDFF'/%3E%3C/svg%3E"
    />

    <!-- Estilos globales (incluye @import tokens.css y Google Fonts) -->
    <link rel="stylesheet" href="/src/styles/global.css" />

    <!-- View Transitions — fade suave entre páginas (Astro built-in) -->
    <ClientRouter />
  </head>

  <body>
    <!--
      SKIP LINK — Accesibilidad teclado (WCAG 2.4.1)
      Oculto con left:-9999px; visible al recibir :focus-visible
      Estilizado en global.css como .skip-link
    -->
    <a class="skip-link" href="#main-content">Ir al contenido principal</a>

    <!-- HEADER — importado directamente para garantizar presencia en cada página -->
    <Header currentPath={currentPath} />

    <!--
      MAIN — Destino del skip link y contenido principal de la página
      id="main-content" requerido por el skip link
    -->
    <!--
      tabindex="-1" permite al skip link enfocar main programáticamente
      (WCAG 2.4.1 — el main no es interactivo nativamente, necesita tabindex para recibir foco)
    -->
    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <!--
      FOOTER — importado directamente; contiene el disclaimer clínico persistente
      requerido por Ley 23/1981 (Colombia) y el threat model T-01-09
    -->
    <Footer />

    <!-- Reveal script — IntersectionObserver activa .reveal → .revealed -->
    <script>
      function initReveal() {
        const elements = document.querySelectorAll<HTMLElement>('.reveal:not(.revealed)');
        if (!elements.length) return;

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '-32px 0px' }
        );

        elements.forEach((el) => observer.observe(el));
      }

      /* Fires on initial load AND after every View Transitions navigation */
      document.addEventListener('astro:page-load', initReveal);
    </script>
  </body>
</html>
