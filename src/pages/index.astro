---
/**
 * index.astro — Página de inicio
 * Contenido pendiente de aprobación médica de la Dra. Pacheco.
 * Estructura base con BaseLayout (Header + Footer incluidos).
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import PlaceholderNotice from '../components/PlaceholderNotice.astro';
---

<BaseLayout
  title="Dra. María Bernarda Pacheco Martelo — Pediatra"
  description="Sitio profesional de medicina pediátrica. Información en proceso de verificación."
  robots="noindex, nofollow"
  currentPath="/"
>
  <!-- HERO placeholder — será reemplazado en plan 01-05 (Hero Section) -->
  <section class="hero-placeholder" aria-labelledby="hero-heading">
    <div class="container">
      <PlaceholderNotice
        message="Contenido del sitio en preparación. Disponible próximamente."
        placeholderId="PH-HERO"
      />
      <h1 id="hero-heading">MARÍA BERNARDA PACHECO</h1>
      <p class="hero-role">Pediatra</p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-placeholder {
    min-height: 60vh;
    display: flex;
    align-items: center;
    background-color: var(--color-lavender);
    padding-block: var(--space-3xl);
  }

  .hero-placeholder .container {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  h1 {
    color: var(--color-primary);
  }

  .hero-role {
    font-family: var(--font-sans);
    font-weight: var(--font-light);
    font-size: var(--text-body);
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
</style>
